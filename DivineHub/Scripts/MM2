local Material = loadstring(game:HttpGet("https://raw.githubusercontent.com/D7ity/UI-LIB/main/Deity"))()

local X = Material.Load({
  Title ="Divine | ".. game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
  Style = 1,
  SizeX = 375,
  SizeY = 300,
  Theme = "Dark"
})

local Y = X.New({Title = "Main"})

local Z = X.New({Title = "Esp"})

local A = X.New({Title = "Local Player"})
Y.Toggle({
    Text = 'Autofarm Coins',
    Enabled = false,
    Callback = function(state)
        if state then
            getgenv().Coin = true       
            while wait() do
                local children = game.Workspace:GetChildren()
                for _, child in pairs(children) do
                    for _, child in pairs(child:GetChildren()) do
                        table.insert(children, child)
                    end
                    if child:IsA("BasePart") and child.Name == "Coin_Server" then
                        if getgenv().Coin == true then
                            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = child.CFrame
                            wait(2.9)
                            print("WOrking")
                        end
                    end
                end
            end
        else
            getgenv().Coin = false
        end
    end
})

Y.Toggle({
    Text = 'XP Farm',
    Enabled = false,
    Callback = function(t)
        if t then
            getgenv().XPFarm = true
            while wait() do
                if getgenv().XPFarm == true then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(-0.0499992371, 156.810242, 15.8749695, 1, 0, 0, 0, 1, 0, 0, 0, 1)
                    wait(5)
                end
            end
        else
            getgenv().XPFarm = false
        end
    end
})
Y.Toggle({
    Text = 'Kill All',
    Enabled = false,
    Callback = function(state)
        if state then
            getgenv().killall = true
            while wait() do
                if getgenv().killall == true then
                    local Players = game:GetService("Players")
                    local lp = Players.LocalPlayer
                    local function GetClosestPlayer()
                        local target = nil
                        local distance = math.huge
 
                        for i,v in next, Players:GetPlayers() do
                            if v and v ~= lp and v.Character and v.Character:FindFirstChildOfClass('Humanoid') and v.Character:FindFirstChildOfClass('Humanoid').RootPart then
                                local plrdist = lp:DistanceFromCharacter(v.Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame.p)
                                if plrdist < distance then
                                    target = v
                                    distance = plrdist
                                end
                            end
                        end
                        return target
                    end
                    lp.Character:FindFirstChildOfClass("Humanoid").RootPart.CFrame = GetClosestPlayer().Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame

                    local args = {
                        [1] = "Slash"
                    }
                    game:GetService("Players").LocalPlayer.Character.Knife.Stab:FireServer(unpack(args))
                end
            end
        else
            getgenv().killall = false
        end
    end
})

function sherrif()
    for i, v in pairs(game.Players:children()) do
        if  v.Backpack:findFirstChild("Gun") or v.Character:findFirstChild("Gun") then
            return v
        end
    end
end
Y.Toggle({
    Text = 'Kill Sherrif',
    Enabled = false,
    Callback = function(t)
        if t then
            getgenv().ksherrif = true
            while wait() do
                if getgenv().ksherrif == true then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = sherrif().Character.HumanoidRootPart.CFrame
                    local args = {
                        [1] = "Slash"
                    }
                    game:GetService("Players").LocalPlayer.Character.Knife.Stab:FireServer(unpack(args))
                end
            end
        end
    end
})

Y.Toggle({
    Text = 'Aimlock (Hold E)',
    Enabled = false,
    Callback = function(state)
        if state then
            getgenv().Aimlock = true
            local LocalPlayer = game.Players.LocalPlayer
            local Camera = workspace.CurrentCamera
            local Mouse = LocalPlayer:GetMouse()
            function ClosestPlayer()
                local Target = nil
                local MaxDistance = math.huge
                for i,v in pairs(game.Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild('Humanoid') and v.Character.Humanoid.Health >= 1 then
                        local Magnitude = (Mouse.Hit.p - v.Character.HumanoidRootPart.CFrame.Position).Magnitude
                        if Magnitude < MaxDistance then
                            MaxDistance = Magnitude
                            Target = v
                        end
                    end
                end
            return Target
            end
            local UserInputService = game:GetService('UserInputService')
            local TweenService = game:GetService('TweenService')
            local RunService = game:GetService('RunService')
            
            function TweenCamera(Pos)
                local Tween = TweenService:Create(Camera, TweenInfo.new(0.05), {CFrame = Pos})
                Tween:Play()
                end
                local Enabled = false
                UserInputService.InputBegan:Connect(function(Input)
                    if getgenv().Aimlock == true then
                        if Input.KeyCode == Enum.KeyCode.E then
                            Enabled = true
                        end 
                    elseif getgenv().Aimlock == false then 
                        Enabled = false
                    end 
                end)
                
                UserInputService.InputEnded:Connect(function(Input)
                    if Input.KeyCode == Enum.KeyCode.E then
                        Enabled = false
                    end
                end)
                
                RunService.RenderStepped:Connect(function()
                    if Enabled then
                        coroutine.wrap(TweenCamera(CFrame.new(Camera.CoordinateFrame.p, ClosestPlayer().Character.Head.CFrame.p)))()
                    end
                end)
                
        else    
            getgenv().Aimlock = false 
        end
    end
 
})

Y.Button({ Text = "Tp To Gun", Callback = function()
    if game.Workspace.GunDrop.CFrame ~= nil then
        game:GetService("Players").LocalPlayer.Character.HumanoidRootPart.CFrame = game.Workspace.GunDrop.CFrame 
    end
end
})

Z.Toggle({
    Text = 'Torso: All Roles ',
    Enabled = false,
    Callback = function(state)
        if state then
            getgenv().AllRole = true
            while wait() do
                if getgenv().AllRole == true then
                    for i, v in pairs(game.Players:children()) do
                        for i, a in pairs(v.Character.Head:children()) do
                            if a.ClassName == "BoxHandleAdornment" then
                                a:remove()
                            end
                        end
                    end
                    wait(5)
                    for i, v in pairs(game.Players:children()) do
                        if v.Backpack:findFirstChild("Knife") or v.Character:findFirstChild("Knife") then
                            local esp = Instance.new("BoxHandleAdornment")
                            esp.Parent = v.Character.Head
                            esp.Size = Vector3.new(1,1,1)
                            esp.Color3 = Color3.new(255, 0, 0)
                            esp.AlwaysOnTop = true
                            esp.Adornee = v.Character.Head
                            esp.Visible = true
                            esp.ZIndex = 2
                        elseif v.Backpack:findFirstChild("Gun") or v.Character:findFirstChild("Gun") then
                            local esp = Instance.new("BoxHandleAdornment")
                            esp.Parent = v.Character.Head
                            esp.Size = Vector3.new(1,1,1)
                            esp.Color3 = Color3.new(0, 0, 255)
                            esp.AlwaysOnTop = true
                            esp.Adornee = v.Character.Head
                            esp.Visible = true
                            esp.ZIndex = 2
                        else
                            local esp = Instance.new("BoxHandleAdornment")
                            esp.Parent = v.Character.Head
                            esp.Size = Vector3.new(1,1,1)
                            esp.Color3 = Color3.new(0, 255, 0)
                            esp.AlwaysOnTop = true
                            esp.Adornee = v.Character.Head
                            esp.Visible = true
                            esp.ZIndex = 2
                        end                        
                    end
                end
            end
        else
            getgenv().AllRole = false
            if getgenv().AllRole == false then
                for i, v in pairs(game.Players:children()) do
                    for i, a in pairs(v.Character.Head:children()) do
                        if a.ClassName == "BoxHandleAdornment" then
                            a:remove()
                        end
                    end
                end
            end
        end                 
    end
})

