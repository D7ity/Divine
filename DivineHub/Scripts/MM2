Z.Button({ Text = "Charm: Sherrif", Callback = function()
    function findgun()
        for i,v in pairs(game.Players:GetPlayers()) do 
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                return v.Name
             end
        end
         return nil
    end

    local pig = findgun()

    function charmsherrif()
        for i,v in pairs(game.Players:GetPlayers()) do
            if v.Name == pig then
                for i, v in pairs(v.Character:GetDescendants()) do
                    if v:IsA("Part") or v:IsA("MeshPart") then
                        if v.Name == "BoxHandleAdornment" then
                            v:Destroy()
                        end
                        local funny = Instance.new("BoxHandleAdornment")
                        funny.Parent = v
                        funny.Adornee = v
                        funny.AlwaysOnTop = true
                        funny.Transparency = .7
                        funny.ZIndex = 0
                        funny.Size = v.size
                        funny.Color3 = Color3.fromRGB(0, 12, 255)
                    end
                end
            end
        end
    end
    charmsherrif()
end})

Z.Button({ Text = "Charm: Murderer", Callback = function()
    function findknife()
        for i,v in pairs(game.Players:GetPlayers()) do 
            if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                return v.Name
            end
        end
        return nil
    end

    local imposter = findknife()

    function charmmurd()
        for i,v in pairs(game.Players:GetPlayers()) do
            if v.Name == imposter then
                for i, v in pairs(v.Character:GetDescendants()) do
                    if v:IsA("Part") or v:IsA("MeshPart") then
                        if v.Name == "BoxHandleAdornment" then
                            v:Destroy()
                        end
                        local funny = Instance.new("BoxHandleAdornment")
                        funny.Parent = v
                        funny.Adornee = v
                        funny.AlwaysOnTop = true
                        funny.Transparency = .7
                        funny.ZIndex = 0
                        funny.Size = v.size
                        funny.Color3 = Color3.fromRGB(255, 0, 4)
                    end
                end
            end
        end
    end
    charmmurd()
end})



Z.Button({ Text = "Notif", Callback = function()
    local function Notify(...)
        game.StarterGui:SetCore('SendNotification',...)
    end
        
        
    function findknife()
        for i,v in pairs(game.Players:GetPlayers()) do 
            if v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife") then
                return v.Name
            end
        end
        return nil
    end
        
        
    function findgun()
        for i,v in pairs(game.Players:GetPlayers()) do 
            if v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun") then
                return v.Name
            end
        end
        return nil
    end
        
    local imposter = findknife()
    local pig = findgun()

    if imposter and pig then
        Notify({Title="The Murderer is";Text=imposter;Icon="http://www.roblox.com/Thumbs/Avatar.ashx?x=150&y=150&Format=Png&username="..imposter})
        Notify({Title="The Sheriff is";Text=pig;Icon="http://www.roblox.com/Thumbs/Avatar.ashx?x=150&y=150&Format=Png&username="..pig})
    end 
end})



local tp = {
    "Lobby",
    "Map",
    "Closest Player",
    "Sherrif",
    "Murderer"
}

function murderer()
    for i, v in pairs(game.Players:children()) do
        if  v.Backpack:findFirstChild("Knife") or v.Character:findFirstChild("Knife") then
            return v
        end
    end
end
    


A.Dropdown({Text = "Select Teleport", Options = tp, Callback = function(currentoption)
    if currentoption == "Lobby" then
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(-0.0499992371, 156.810242, 15.8749695, 1, 0, 0, 0, 1, 0, 0, 0, 1)
    elseif currentoption == "Map" then
        local children = game.Workspace:GetChildren()
        for _, child in pairs(children) do
            for _, child in pairs(child:GetChildren()) do
            table.insert(children, child)
        end
        if child:IsA("BasePart") and child.Name == "Coin_Server" then
            getgenv().TPMap = true
                if getgenv().TPMap == true then
                    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = child.CFrame
                    getgenv().TPMap = false
                end
            end
        end
    elseif currentoption == "Closest Player" then
        local Players = game:GetService("Players")
        local lp = Players.LocalPlayer
        local function GetClosestPlayer()
            local target = nil
            local distance = math.huge

            for i,v in next, Players:GetPlayers() do
                if v and v ~= lp and v.Character and v.Character:FindFirstChildOfClass('Humanoid') and v.Character:FindFirstChildOfClass('Humanoid').RootPart then
                    local plrdist = lp:DistanceFromCharacter(v.Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame.p)
                    if plrdist < distance then
                        target = v
                        distance = plrdist
                    end
                end
            end
        return target
        end
        lp.Character:FindFirstChildOfClass("Humanoid").RootPart.CFrame = GetClosestPlayer().Character:FindFirstChildOfClass('Humanoid').RootPart.CFrame
    elseif currentoption == "Sherrif" then
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = sherrif().Character.HumanoidRootPart.CFrame
    elseif currentoption == "Murderer" then
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = murderer().Character.HumanoidRootPart.CFrame
    end
end,
})




